APP_ENV=local

LLM_PROVIDER=ollama
EMBEDDING_PROVIDER=ollama

# When Ollama runs on your Mac and the app runs in Docker Desktop.
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen3:8b
OLLAMA_EMBEDDING_MODEL=bge-m3
OLLAMA_REASONING=false
OLLAMA_NUM_PREDICT=800

DATA_PATH=/app/data/family_offices_final.xlsx
CHROMA_PATH=/app/vector_db
CHAT_HISTORY_PATH=/app/state/chat_history.sqlite3
SHOW_ADMIN_PANEL=false

RETRIEVAL_TOP_K=6
RETRIEVAL_CANDIDATE_TOP_K=25
RETRIEVAL_SCORE_THRESHOLD=0.0
RERANKER_ENABLED=true
RERANKER_PROVIDER=flag_embedding
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_DEVICE=auto
RERANK_TOP_K=5

# Claude optional inference only.
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-3-5-sonnet-latest
